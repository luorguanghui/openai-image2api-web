# OpenAI API Key（必填，或在请求中临时提供）
OPENAI_API_KEY=

# API 基础 URL（默认为 apimart.ai）
# 如果使用 OpenAI 官方 API，改为 https://api.openai.com
API_BASE_URL=https://api.apimart.ai

# 服务端口
PORT=3001

# CORS 允许的来源（* 表示允许所有）
CORS_ORIGIN=http://localhost:5173

# 速率限制配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10

# 任务轮询配置（异步模式）
# 首次查询延迟（毫秒）
TASK_POLL_INITIAL_DELAY=10000
# 轮询间隔（毫秒）
TASK_POLL_INTERVAL=3000
# 超时时间（毫秒，建议 >= 180000）
TASK_POLL_TIMEOUT=180000

# 运行环境
NODE_ENV=development
