# ============================================================
# OpenAI Image2API - 环境变量配置
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env:  cp .env.example .env
#   2. 填入你的 API Key
#   3. 根据需要调整其他配置
#
# 注意：不要将 .env 文件提交到 Git！
# ============================================================

# ── 必填 ──

# API Key（必填，支持 apimart.ai 或 OpenAI 官方）
OPENAI_API_KEY=

# ── API 配置 ──

# API 基础 URL（默认为 apimart.ai）
# 如果使用 OpenAI 官方 API，改为 https://api.openai.com
API_BASE_URL=https://api.apimart.ai

# ── 服务配置 ──

# 服务端口（默认 3001）
PORT=3001

# CORS 允许的来源（默认 "*" 允许所有，生产环境建议设为你的域名）
# 开发时设为 http://localhost:5173
# 生产时设为 https://your-domain.com
CORS_ORIGIN=*

# 运行环境（development / production）
NODE_ENV=production

# ── 速率限制 ──

# 速率限制窗口时间（毫秒，默认 60000 即 1 分钟）
RATE_LIMIT_WINDOW_MS=60000

# 窗口内最大请求数（默认 60）
RATE_LIMIT_MAX=60

# ── 任务轮询配置（异步模式，适用于 gpt-image-2 / gpt-image-1.5） ──

# 首次查询延迟（毫秒，默认 10000）
TASK_POLL_INITIAL_DELAY=10000

# 轮询间隔（毫秒，默认 3000）
TASK_POLL_INTERVAL=3000

# 超时时间（毫秒，默认 180000 即 3 分钟，high + 4K 组合耗时可达 130 秒）
TASK_POLL_TIMEOUT=180000

# HTTP 长请求超时（毫秒，默认 240000，即 4 分钟）
# 开发环境通过 Vite 代理时建议大于 TASK_POLL_TIMEOUT
HTTP_REQUEST_TIMEOUT=240000
